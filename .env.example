# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# База данных (путь к SQLite, по умолчанию db.sqlite3 в корне проекта)
DATABASE_PATH=db.sqlite3

# CORS — разрешённые источники для API (через запятую)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# CSRF — доверенные origins для форм, админки (через запятую)
# Для production: https://ваш-домен.ru
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000
